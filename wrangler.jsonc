/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "agent-workflow-template",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-24",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	// Browser Run for web scraping and content extraction
	// https://developers.cloudflare.com/browser-run/
	"browser": {
		"binding": "BROWSER"
	},
	// D1 database for workspace persistence
	// 1. Create: npx wrangler d1 create agent-workspace-db
	// 2. Copy the database_id from the output and paste it below
	// 3. Run schema: npx wrangler d1 execute agent-workspace-db --remote --file=./schema.sql
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "agent-workspace-db",
			"database_id": "YOUR_D1_DATABASE_ID"
		}
	],
	"vars": {
		// Optional: AI Gateway ID for analytics, caching, and rate limiting.
		// Create one at https://dash.cloudflare.com/?to=/:account/ai/ai-gateway
		"AI_GATEWAY_ID": "",
		// Optional: Set to "true" to bypass AI Gateway cache.
		"AI_GATEWAY_SKIP_CACHE": "false",
		// Optional: AI Gateway cache TTL in seconds.
		"AI_GATEWAY_CACHE_TTL": "3600",
		// Optional: set this to a remote MCP server endpoint that supports Streamable HTTP JSON-RPC.
		"MCP_SERVER_URL": "",
		// Optional: comma-separated MCP tool names the agent is allowed to call.
		"MCP_TOOL_ALLOWLIST": "",
		// Set to "true" for local development to allow X-Dev-User-Email header
		"ALLOW_DEV_AUTH": "false"
	},
	"upload_source_maps": true
}
